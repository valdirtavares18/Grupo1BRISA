# ===========================================
# Produção (Vercel + Turso) - obrigatório
# ===========================================
# Crie um banco em https://turso.tech e preencha:
TURSO_DATABASE_URL=libsql://seu-db-nome.turso.io
TURSO_AUTH_TOKEN=seu-token-aqui

# JWT (obrigatório em produção)
JWT_SECRET=uma-string-longa-e-secreta-mude-em-producao

# ===========================================
# Opcional - SMS (Twilio)
# ===========================================
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# ===========================================
# Envio de email - cadastro/login
# ===========================================
# Opção A - Gmail (recomendado: sem verificação de domínio, envia pra qualquer um)
# Crie uma "Senha de app" em: https://myaccount.google.com/apppasswords
# GMAIL_USER=seuemail@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Opção B - Resend (exige verificar domínio para enviar a outros)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev

# ===========================================
# Local (SQLite) - não defina TURSO_* para usar presenca.db
# ===========================================
